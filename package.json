{
  "name": "cursor-like-ide",
  "version": "1.0.0",
  "description": "A Cursor-like AI-powered IDE with agentic workflow - Same tech stack as Cursor",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["cursor", "ai", "ide", "electron", "vscode", "agentic", "llm"],
  "author": "Bharath Ram Naiks",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "chokidar": "^3.5.3",
    "dotenv": "^16.3.1",
    "electron-log": "^5.0.3",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "lowdb": "^5.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.24.0",
    "tree-sitter": "^0.20.6",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "build": {
    "appId": "com.cursorlike.ide",
    "productName": "CursorLikeIDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  }
}
